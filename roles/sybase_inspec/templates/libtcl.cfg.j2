; SAP ASE Open Client SSL driver configuration
; Deployed by sybase_inspec Ansible role
;
; Note: The ssl filter library name varies by platform and SDK version:
;   libsybfssl64.so  - SAP ASE 16.x (64-bit, FIPS-capable)
;   libsybfssl.so    - SAP ASE 16.x (32-bit, FIPS-capable)
;   libsybssl64.so   - Older SAP ASE versions
; Use sybase_ssl_filter_lib variable to override if needed.

[DIRECTORY]

[SECURITY]

[FILTERS]
ssl = {{ sybase_ssl_filter_lib | default('libsybfssl64.so') }}

[DEFAULT]